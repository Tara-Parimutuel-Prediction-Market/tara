# Redis
REDIS_URL=redis://localhost:2345

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_actual_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username

# Database Configuration (existing)
DB_HOST=localhost
DB_PORT=1111
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=x_db

# Application Configuration (existing)
PORT=xxxx
FRONTEND_URL=http://localhost:1234
ADMIN_DEV_SECRET=your_admin_secret
ADMIN_TELEGRAM_ID=your_admin_telegram_id

# Security — Phone Hash
# HMAC-SHA-256 secret used to hash phone numbers before storing.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')|0"
# NEVER change after go-live — existing phone hashes will become invalid.
PHONE_HASH_SECRET=replace_with_64_char_hex_secret

# Football Data (football-data.org — free tier key)
FOOTBALL_DATA_API_KEY=your_api_key_here

# Telegram Mini App Configuration
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/bot/webhook
TELEGRAM_MINI_APP_URL=https://your-mini-app-url.com