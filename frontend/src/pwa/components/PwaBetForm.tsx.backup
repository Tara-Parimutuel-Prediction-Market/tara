import { FC, useState } from "react";
import {
  useTonWallet,
  useTonConnectUI,
  TonConnectButton,
} from "@tonconnect/ui-react";
import { Market, placeBetWithWallet } from "@/api/client";
import { PwaPaymentSelector } from "./PwaPaymentSelector";

interface PwaBetFormProps {
  market: Market;
  onBetPlaced?: (updatedMarket?: Market) => void;
}

type Step = "configure" | "payment" | "confirm";
type PaymentMethod = "ton" | "dkbank" | "credits" | null;

export const PwaBetForm: FC<PwaBetFormProps> = ({ market, onBetPlaced }) => {
  const [step, setStep] = useState<Step>("configure");
  const [selectedOutcomeId, setSelectedOutcomeId] = useState<string | null>(null);
  const [amount, setAmount] = useState("");
  const [limitPrice, setLimitPrice] = useState("0.5");
  const [maxShares, setMaxShares] = useState("");
  const [loading, setLoading] = useState(false);
  const [selectedPaymentMethod, setSelectedPaymentMethod] = useState<string>("");
  const [showPaymentSelector, setShowPaymentSelector] = useState(false);
  const [betAmount, setBetAmount] = useState<number>(0);
  const [cidNumber, setCidNumber] = useState("");
  const [selectedPayment, setSelectedPayment] = useState<PaymentMethod>(null);

  const wallet = useTonWallet();
  const [tonConnectUI] = useTonConnectUI();

  // Payment methods definition
  const paymentMethods = [
    {
      id: 'dkbank',
      name: 'DK Bank',
      type: 'dkbank',
      currency: 'BTN',
      enabled: true,
      minAmount: 50,
      maxAmount: 10000,
      icon: '🏦',
    },
    {
      id: 'ton',
      name: 'TON Wallet',
      type: 'ton',
      currency: 'TON',
      enabled: true,
      minAmount: 0.5,
      maxAmount: 100,
      icon: '💎',
    },
    {
      id: 'credits',
      name: 'Test Credits',
      type: 'credits',
      currency: 'CREDITS',
      enabled: true,
      minAmount: 1,
      icon: '🪙',
    },
  ];

  const isSCPM =
    String(market.mechanism || "").toLowerCase().includes("scpm") ||
    market.title.toLowerCase().includes("btc");

  // ─── Currency helpers ───────────────────────────────────────────────────
  const getCurrencySymbol = (method: PaymentMethod) => {
    switch (method) {
      case "dkbank": return "NU";
      case "ton": return "TON";
      case "credits": return "Credits";
      default: return "TON";
    }
  };

  const getConversionRate = (method: PaymentMethod) => {
    switch (method) {
      case "dkbank": return 0.8; // 1 TON = 0.8 NU (so 0.8 TON = 0.64 NU)
      case "ton": return 1;
      case "credits": return 100; // 1 TON = 100 credits
      default: return 1;
    }
  };

  const getAmountInCurrency = (method: PaymentMethod) => {
    if (!method) return parsedAmount;
    return parsedAmount * getConversionRate(method);
  };

  const selectedOutcome = market.outcomes.find((o) => o.id === selectedOutcomeId);
  const parsedAmount = parseFloat(amount || "0");
  const isConfigValid =
    !!selectedOutcomeId &&
    (!isSCPM || (!!maxShares && !!limitPrice));

  // ─── Payout calculation ───────────────────────────────────────────────────
  const calcPayout = () => {
    if (!selectedOutcome || parsedAmount <= 0) return null;
    if (isSCPM) {
      const b = Number(market.liquidityParam || 1000);
      const prob = Number(selectedOutcome.lmsrProbability || 0.5);
      const avgPrice = prob + (parsedAmount / (b || 1)) * (1 - prob) / 2;
      const payout = parsedAmount / (avgPrice || 1);
      const profit = payout - parsedAmount;
      const roi = parsedAmount > 0 ? (profit / parsedAmount) * 100 : 0;
      if (isNaN(payout) || isNaN(profit) || isNaN(roi)) return null;
      return { payout, profit, roi };
    }
    return null;
  };
  const payout = calcPayout();

  // ─── Payment execution ────────────────────────────────────────────────────
  const handlePaymentSuccess = async (paymentMethod: string) => {
    await placeBetAfterPayment(paymentMethod);
  };

  const handlePaymentFailure = (error: string) => {
    setLoading(false);
    setShowPaymentSelector(false);
    alert(`Payment failed: ${error}`);
  };

  const placeBetAfterPayment = async (paymentMethod: string) => {
    if (!selectedOutcomeId || !amount) return;
    try {
      const bet = parseFloat(amount || "0");
      if (bet <= 0) throw new Error("Amount must be positive");

      if (paymentMethod === "ton") {
        if (!wallet) throw new Error("TON wallet required for TON payments");
        const PLATFORM_WALLET = "EQD...";
        const nanoAmount = (bet * 1_000_000_000).toString();
        const tx = await tonConnectUI.sendTransaction({
          validUntil: Math.floor(Date.now() / 1000) + 600,
          messages: [
            {
              address: PLATFORM_WALLET,
              amount: nanoAmount,
              payload: btoa(`bet:${market.id}:${selectedOutcomeId}`),
            },
          ],
        });
        await placeBetWithWallet(market.id, {
          outcomeId: selectedOutcomeId,
          amount: bet,
          walletAddress: wallet.account.address,
          txHash: tx.boc,
        });
      } else {
        const updatedMarket = { ...market };
        updatedMarket.totalPool = (Number(market.totalPool || 0) + bet).toString();
        updatedMarket.outcomes = market.outcomes.map((o) => {
          if (o.id === selectedOutcomeId) {
            const newAmount = Number(o.totalBetAmount || 0) + bet;
            let newProb = Number(o.lmsrProbability || 0);
            if (isSCPM) {
              const b = Number(market.liquidityParam || 1000);
              newProb = Math.min(0.99, newProb + (bet / b) * (1 - newProb));
            } else {
              newProb = newAmount / Number(updatedMarket.totalPool || 1);
            }
            return { ...o, totalBetAmount: newAmount.toString(), lmsrProbability: newProb };
          } else {
            let newProb = Number(o.lmsrProbability || 0);
            if (isSCPM) {
              const b = Number(market.liquidityParam || 1000);
              newProb = Math.max(0.01, newProb - (bet / b) * newProb);
            } else {
              newProb = Number(o.totalBetAmount || 0) / Number(updatedMarket.totalPool || 1);
            }
            return { ...o, lmsrProbability: newProb };
          }
        });
        await new Promise((resolve) => setTimeout(resolve, 800));
        if (onBetPlaced) onBetPlaced(updatedMarket);
      }

      // Reset to initial state
      setStep("configure");
      setSelectedOutcomeId(null);
      setAmount("");
      setBetAmount(0);
      setSelectedPayment(null);
      setCidNumber("");
      setShowPaymentSelector(false);
    } catch (error: any) {
      alert(`Bet placement failed: ${error.message}`);
    } finally {
      setLoading(false);
    }
  };

  const handleContinueToPayment = () => {
    if (!isConfigValid) return;
    if (parsedAmount <= 0) {
      alert("Please enter a valid bet amount");
      return;
    }
    setBetAmount(parsedAmount);
    setStep("payment");
  };

  const handleConfirmBet = () => {
    if (!selectedPayment) return;
    if (selectedPayment === "dkbank" && !cidNumber) {
      alert("Please enter your CID number");
      return;
    }
    setLoading(true);
    setShowPaymentSelector(true);
  };

  // ─── Step indicator ───────────────────────────────────────────────────────
  const steps: { key: Step; label: string }[] = [
    { key: "configure", label: "Configure" },
    { key: "payment", label: "Payment" },
    { key: "confirm", label: "Confirm" },
  ];
  const stepIndex = steps.findIndex((s) => s.key === step);

  return (
    <div style={styles.container}>
      {/* Header + Step progress */}
      <div style={styles.header}>
        <span style={styles.headerTitle}>Place a Bet</span>
        <div style={styles.stepBar}>
          {steps.map((s, i) => (
            <div key={s.key} style={styles.stepItem}>
              <div
                style={{
                  ...styles.stepDot,
                  background: i <= stepIndex ? "#6ab3f3" : "#2a3a4a",
                  border: `2px solid ${i === stepIndex ? "#6ab3f3" : "transparent"}`,
                  boxShadow: i === stepIndex ? "0 0 8px #6ab3f344" : "none",
                }}
              />
              <span
                style={{
                  ...styles.stepLabel,
                  color: i <= stepIndex ? "#6ab3f3" : "#708499",
                }}
              >
                {s.label}
              </span>
              {i < steps.length - 1 && (
          ))}
        </select>
      </div>

      {/* Payment Method Selection */}
      {selectedOutcomeId && (
        <div style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
          <label style={{ color: "#6ab3f3", fontWeight: 600, marginBottom: "8px" }}>PAYMENT METHOD</label>
          
          {/* DK Bank Payment */}
          <div style={{ 
            background: "#2a3a4a", 
            border: "1px dashed #6ab3f3",
            borderRadius: "12px",
            padding: "16px",
            cursor: "pointer",
            opacity: selectedPayment === 'dkbank' ? 1 : 0.7
          }}
          onClick={() => setSelectedPayment('dkbank')}
          >
            <div style={{ marginBottom: "12px" }}>
              <div style={{ color: "#6ab3f3", fontWeight: 600, marginBottom: "8px" }}>
                🏦 DK Bank Payment
              id="credits"
              selected={selectedPayment === "credits"}
              onSelect={() => setSelectedPayment("credits")}
              icon="⭐"
              title="Credits"
              subtitle="Use platform credits"
            />
          </div>

          {!wallet && (
            <div style={styles.tonConnectRow}>
              <span style={styles.tonConnectHint}>Connect your TON wallet to enable crypto payment</span>
              <TonConnectButton />
            </div>
          )}

          {selectedPayment === "dkbank" && (
            <Field label="CID NUMBER">
              <input
                type="text"
                placeholder="Enter your CID number"
                value={cidNumber}
                onChange={(e) => setCidNumber(e.target.value)}
                style={styles.input}
                autoFocus
              />
            </Field>
          )}

          {selectedPayment && payout && (
            <div style={styles.payoutCard}>
              <div style={styles.payoutRow}>
                <span style={styles.payoutLabel}>ESTIMATED PAYOUT</span>
                <span style={styles.payoutGreen}>
                  {(payout.payout * getConversionRate(selectedPayment)).toFixed(2)} {getCurrencySymbol(selectedPayment)}
                </span>
              </div>
              <div style={styles.payoutRow}>
                <span style={styles.payoutLabel}>POTENTIAL PROFIT</span>
                <span style={styles.payoutBlue}>
                  +{(payout.profit * getConversionRate(selectedPayment)).toFixed(2)} ({payout.roi.toFixed(0)}% ROI)
                </span>
              </div>
            </div>
          )}

          {selectedPayment && !isSCPM && selectedOutcomeId && parsedAmount > 0 && (
            <div style={styles.infoNote}>
              Payout is distributed automatically at event end based on the final pool.
            </div>
          )}

          <div style={styles.rowBtns}>
            <button onClick={() => setStep("configure")} style={styles.ghostBtn}>
              ← Back
            </button>
            <button
              onClick={() => setStep("confirm")}
              disabled={
                !selectedPayment ||
                (selectedPayment === "dkbank" && !cidNumber) ||
                (selectedPayment === "ton" && !wallet)
              }
              style={{
                ...styles.primaryBtn,
                flex: 1,
                opacity:
                  !selectedPayment ||
                  (selectedPayment === "dkbank" && !cidNumber) ||
                  (selectedPayment === "ton" && !wallet)
                    ? 0.45
                    : 1,
              }}
            >
              Review Order →
            </button>
          </div>
        </div>
      )}

      {/* ── STEP 3: Confirm ───────────────────────────────────────────────── */}
      {step === "confirm" && (
        <div style={styles.stepContent}>
          <p style={styles.stepDescription}>Review your bet before submitting.</p>

          <div style={styles.confirmCard}>
            <ConfirmRow label="Market" value={market.title} />
            <ConfirmRow label="Outcome" value={selectedOutcome?.label || "—"} />
            <ConfirmRow label="Amount" value={`${getAmountInCurrency(selectedPayment).toFixed(2)} ${getCurrencySymbol(selectedPayment)}`} />
            {isSCPM && (
              <>
                <ConfirmRow label="Max Shares" value={maxShares || "—"} />
                <ConfirmRow label="Limit Price" value={limitPrice || "—"} />
              </>
            )}
            <ConfirmRow
              label="Payment"
              value={
                selectedPayment === "dkbank"
                  ? `DK Bank (CID: ${cidNumber})`
                  : selectedPayment === "ton"
                  ? "TON Wallet"
                  : "Credits"
              }
            />
            {payout && (
              <ConfirmRow 
                label="Est. Payout" 
                value={`${(payout.payout * getConversionRate(selectedPayment)).toFixed(2)} ${getCurrencySymbol(selectedPayment)}`} 
                accent 
              />
            )}
          </div>

          <div style={styles.rowBtns}>
            <button onClick={() => setStep("payment")} style={styles.ghostBtn}>
              ← Back
            </button>
            <button
              onClick={handleConfirmBet}
              disabled={loading}
              style={{ ...styles.confirmBtn, flex: 1, opacity: loading ? 0.6 : 1 }}
            >
              {loading ? "Processing…" : "✓ Confirm Bet"}
            </button>
          </div>
        </div>
      )}

      {/* Payment Selector modal (existing component) */}
      {showPaymentSelector && (
        <PwaPaymentSelector
          amount={betAmount}
          description={`Bet on ${selectedOutcome?.label} in "${market.title}"`}
          onPaymentSuccess={handlePaymentSuccess}
          onPaymentFailure={handlePaymentFailure}
        />
      )}
    </div>
  );
};

// ─── Sub-components ──────────────────────────────────────────────────────────

const Field: FC<{ label: string; children: React.ReactNode; style?: React.CSSProperties }> = ({
  label,
  children,
  style,
}) => (
  <div style={{ display: "flex", flexDirection: "column", gap: "6px", ...style }}>
    <label style={styles.label}>{label}</label>
    {children}
  </div>
);

const PaymentCard: FC<{
  id: string;
  selected: boolean;
  onSelect: () => void;
  icon: string;
  title: string;
  subtitle: string;
  disabled?: boolean;
  badge?: string;
}> = ({ selected, onSelect, icon, title, subtitle, disabled, badge }) => (
  <button
    onClick={onSelect}
    disabled={disabled}
    style={{
      background: selected ? "rgba(106,179,243,0.12)" : "#1e2c3a",
      border: `1.5px solid ${selected ? "#6ab3f3" : "#2a3a4a"}`,
      borderRadius: "10px",
      padding: "14px 12px",
      cursor: disabled ? "not-allowed" : "pointer",
      textAlign: "left",
      opacity: disabled ? 0.45 : 1,
      transition: "all 0.15s ease",
      position: "relative",
      flex: 1,
    }}
  >
    <div style={{ fontSize: "1.3rem", marginBottom: "6px" }}>{icon}</div>
    <div style={{ color: selected ? "#6ab3f3" : "#c8d8e8", fontWeight: 700, fontSize: "0.82rem" }}>
      {title}
    </div>
    <div style={{ color: "#708499", fontSize: "0.7rem", marginTop: "3px", lineHeight: 1.3 }}>
      {subtitle}
    </div>
    {badge && (
      <span
        style={{
          position: "absolute",
          top: "8px",
          right: "8px",
          background: "#4CAF5022",
          color: "#4CAF50",
          fontSize: "0.6rem",
          fontWeight: 700,
          padding: "2px 5px",
          borderRadius: "4px",
        }}
      >
        {badge}
      </span>
    )}
  </button>
);

const ConfirmRow: FC<{ label: string; value: string; accent?: boolean }> = ({
  label,
  value,
  accent,
}) => (
  <div style={styles.confirmRow}>
    <span style={styles.confirmLabel}>{label}</span>
    <span style={{ ...styles.confirmValue, color: accent ? "#4CAF50" : "#e8eef4" }}>{value}</span>
  </div>
);

// ─── Styles ──────────────────────────────────────────────────────────────────

const styles: Record<string, React.CSSProperties> = {
  container: {
    background: "#17212b",
    border: "1px solid #2a3a4a",
    borderRadius: "14px",
    padding: "20px",
    marginTop: "24px",
  },
  header: {
    marginBottom: "20px",
  },
  headerTitle: {
    fontSize: "1rem",
    fontWeight: 700,
    color: "#6ab3f3",
    display: "block",
    marginBottom: "14px",
  },
  stepBar: {
    display: "flex",
    alignItems: "center",
  },
  stepItem: {
    display: "flex",
    alignItems: "center",
    gap: "6px",
    flexShrink: 0,
  },
  stepDot: {
    width: "10px",
    height: "10px",
    borderRadius: "50%",
    transition: "all 0.2s ease",
    flexShrink: 0,
  },
  stepLabel: {
    fontSize: "0.7rem",
    fontWeight: 600,
    letterSpacing: "0.04em",
    transition: "color 0.2s ease",
  },
  stepLine: {
    width: "32px",
    height: "2px",
    margin: "0 4px",
    borderRadius: "2px",
    transition: "background 0.2s ease",
    flexShrink: 0,
  },
  stepContent: {
    display: "flex",
    flexDirection: "column",
    gap: "14px",
  },
  stepDescription: {
    color: "#708499",
    fontSize: "0.85rem",
    margin: "0 0 2px 0",
    lineHeight: 1.4,
  },
  label: {
    fontSize: "0.68rem",
    color: "#708499",
    fontWeight: 700,
    letterSpacing: "0.05em",
  },
  input: {
    background: "#232e3c",
    border: "1px solid #2a3a4a",
    borderRadius: "8px",
    padding: "10px 12px",
    color: "#fff",
    fontSize: "0.95rem",
    outline: "none",
    width: "100%",
    boxSizing: "border-box",
  },
  row: {
    display: "flex",
    gap: "12px",
  },
  rowBtns: {
    display: "flex",
    gap: "10px",
    marginTop: "4px",
  },
  amountUnit: {
    position: "absolute",
    right: "12px",
    top: "50%",
    transform: "translateY(-50%)",
    color: "#708499",
    fontSize: "0.78rem",
    fontWeight: 700,
    pointerEvents: "none",
  },
  payoutCard: {
    background: "rgba(82,136,193,0.08)",
    border: "1px solid #5288c133",
    borderRadius: "8px",
    padding: "12px 14px",
    display: "flex",
    flexDirection: "column",
    gap: "6px",
  },
  payoutRow: {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
  },
  payoutLabel: {
    color: "#708499",
    fontSize: "0.68rem",
    fontWeight: 700,
    letterSpacing: "0.04em",
  },
  payoutGreen: {
    color: "#4CAF50",
    fontWeight: 700,
    fontSize: "0.9rem",
  },
  payoutBlue: {
    color: "#6ab3f3",
    fontWeight: 600,
    fontSize: "0.82rem",
  },
  infoNote: {
    color: "#708499",
    fontSize: "0.8rem",
    textAlign: "center",
    background: "#1e2c3a",
    borderRadius: "8px",
    padding: "10px 14px",
    lineHeight: 1.5,
  },
  paymentGrid: {
    display: "flex",
    gap: "10px",
  },
  tonConnectRow: {
    display: "flex",
    flexDirection: "column",
    alignItems: "center",
    gap: "10px",
    background: "#1e2c3a",
    borderRadius: "10px",
    padding: "14px",
  },
  tonConnectHint: {
    color: "#708499",
    fontSize: "0.78rem",
    textAlign: "center",
  },
  confirmCard: {
    background: "#1e2c3a",
    border: "1px solid #2a3a4a",
    borderRadius: "10px",
    overflow: "hidden",
  },
  confirmRow: {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
    padding: "10px 14px",
    borderBottom: "1px solid #2a3a4a44",
  },
  confirmLabel: {
    color: "#708499",
    fontSize: "0.78rem",
    fontWeight: 600,
  },
  confirmValue: {
    fontSize: "0.85rem",
    fontWeight: 600,
    maxWidth: "60%",
    textAlign: "right",
  },
  primaryBtn: {
    background: "#5288c1",
    color: "#fff",
    border: "none",
    borderRadius: "8px",
    padding: "13px 18px",
    fontSize: "0.9rem",
    fontWeight: 700,
    cursor: "pointer",
    transition: "background 0.2s",
    letterSpacing: "0.02em",
  },
  confirmBtn: {
    background: "linear-gradient(135deg, #4CAF50, #388E3C)",
    color: "#fff",
    border: "none",
    borderRadius: "8px",
    padding: "13px 18px",
    fontSize: "0.9rem",
    fontWeight: 700,
    cursor: "pointer",
    letterSpacing: "0.02em",
  },
  ghostBtn: {
    background: "transparent",
    color: "#708499",
    border: "1px solid #2a3a4a",
    borderRadius: "8px",
    padding: "13px 16px",
    fontSize: "0.9rem",
    fontWeight: 600,
    cursor: "pointer",
    whiteSpace: "nowrap",
  },
};